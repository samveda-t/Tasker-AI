WEATHERAPI_KEY=your_weatherapi_key
ORS_API_KEY=your_ors_key
# News API
# NEWS_API_KEY=your_newsapi_key
# NEWS_API_BASE_URL=https://newsapi.org/v2/everything
# Optional override if you need a different host
# ORS_BASE_URL=https://api.openrouteservice.org
# Staging hosts may require the /ors base path:
# ORS_BASE_URL=https://staging.openrouteservice.org/ors
# Routing provider: ors (default) or osrm (no key needed)
# ROUTING_PROVIDER=osrm
# Google Directions (traffic-aware)
# ROUTING_PROVIDER=google
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com/maps/api/directions/json
# GOOGLE_GEOCODE_BASE_URL=https://maps.googleapis.com/maps/api/geocode/json
# GOOGLE_TRAFFIC_MODEL=best_guess
# Optional OSRM host
# OSRM_BASE_URL=https://router.project-osrm.org
# Optional separate geocoder host (useful when ORS_BASE_URL is staging)
# ORS_GEOCODE_BASE_URL=https://api.openrouteservice.org
# Optional Open-Meteo geocoding (key-free)
# OPEN_METEO_GEOCODE_BASE_URL=https://geocoding-api.open-meteo.com/v1/search
# Optional Nominatim settings (fallback if ORS geocode is unavailable)
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# NOMINATIM_USER_AGENT=life-ops-agent/1.0 (you@example.com)
# Cache settings (seconds)
# WEATHER_CACHE_TTL_SEC=600
# GEOCODE_CACHE_TTL_SEC=604800
# ROUTE_CACHE_TTL_SEC=900
# Optional cache file paths
# WEATHER_CACHE_PATH=./.cache/weather.json
# MAPS_CACHE_PATH=./.cache/maps.json

# OpenAI (optional, for LLM-based decisioning)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_DECISION_MODEL=gpt-5
# OPENAI_PARSER_MODEL=gpt-4o-2024-08-06
# OPENAI_TIMEOUT_SEC=15
